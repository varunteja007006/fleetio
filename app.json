{
  "expo": {
    "name": "fleetio",
    "slug": "fleetio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fleetio",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Fleetio uses your location to track route progress and verify checkpoint visits.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Fleetio needs background location to continue tracking while the app is in the background.",
        "UIBackgroundModes": ["location", "fetch"]
      }
    },
    "android": {
      "package": "com.fleetio.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Fleetio needs background location to track your route progress.",
          "locationWhenInUsePermission": "Fleetio uses your location to verify checkpoint visits.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-notifications",
      "expo-secure-store",
      "expo-image-picker",
      "@react-native-vector-icons/lucide",
      [
        "expo-font",
        [
          "./assets/fonts/Lexend-Black.ttf",
          "./assets/fonts/Lexend-Bold.ttf",
          "./assets/fonts/Lexend-ExtraBold.ttf",
          "./assets/fonts/Lexend-ExtraLight.ttf",
          "./assets/fonts/Lexend-Light.ttf",
          "./assets/fonts/Lexend-Medium.ttf",
          "./assets/fonts/Lexend-Regular.ttf",
          "./assets/fonts/Lexend-Semibold.ttf",
          "./assets/fonts/Lexend-Thin.ttf"
        ]
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8adecb3d-16d0-41e9-b845-cf7ba86489ce"
      }
    },
    "owner": "varunteja007006"
  }
}
